# ==============================================================================
# Konfigurasi Koneksi PostgreSQL Aiven Cloud
# Salin file ini menjadi '.env' di komputer lokal Anda dan sesuaikan nilainya.
# JANGAN PERNAH commit file '.env' ke repositori Git Anda!
# ==============================================================================

DB_HOST=your-aiven-pg-host.aivencloud.com
DB_PORT=25060
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_secure_password
DB_SSLMODE=require
